{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/intake.updated.v1.json",
  "title": "intake.updated.v1",
  "description": "Emitted transactionally when staff changes an intake or its application status.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "intake.updated.v1"
    },
    "source": {
      "const": "admissions-service"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "intake_id",
        "programme_id",
        "previous_status",
        "status",
        "version",
        "changed_by",
        "changed_at"
      ],
      "properties": {
        "intake_id": {
          "type": "string",
          "format": "uuid"
        },
        "programme_id": {
          "type": "string",
          "format": "uuid"
        },
        "previous_status": {
          "enum": [
            "draft",
            "open",
            "closed",
            "archived"
          ]
        },
        "status": {
          "enum": [
            "draft",
            "open",
            "closed",
            "archived"
          ]
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "changed_by": {
          "type": "string"
        },
        "changed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "intake.updated.v1",
      "source": "admissions-service",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "intake_id": "11111111-1111-4111-8111-111111111111",
        "programme_id": "11111111-1111-4111-8111-111111111111",
        "previous_status": "draft",
        "status": "draft",
        "version": 1,
        "changed_by": "example-changed.by",
        "changed_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
