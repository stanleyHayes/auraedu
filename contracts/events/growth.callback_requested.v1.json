{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/growth.callback_requested.v1.json",
  "title": "growth.callback_requested",
  "description": "Emitted after a consented admissions callback time request is committed. Contact PII remains in CRM.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "growth.callback_requested.v1"
    },
    "source": {
      "const": "crm-service"
    },
    "subject": {
      "type": "string",
      "format": "uuid"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "callback_request_id",
        "lead_id",
        "preferred_at",
        "timezone",
        "locale",
        "status",
        "requested_at"
      ],
      "properties": {
        "callback_request_id": {
          "type": "string",
          "format": "uuid"
        },
        "lead_id": {
          "type": "string",
          "format": "uuid"
        },
        "preferred_at": {
          "type": "string",
          "format": "date-time"
        },
        "timezone": {
          "type": "string"
        },
        "locale": {
          "enum": [
            "en",
            "en-GH",
            "fr",
            "fr-GH"
          ]
        },
        "status": {
          "const": "requested"
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "growth.callback_requested.v1",
      "source": "crm-service",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "callback_request_id": "11111111-1111-4111-8111-111111111111",
        "lead_id": "11111111-1111-4111-8111-111111111111",
        "preferred_at": "2026-07-19T10:00:00Z",
        "timezone": "example-timezone",
        "locale": "en",
        "status": "requested",
        "requested_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
