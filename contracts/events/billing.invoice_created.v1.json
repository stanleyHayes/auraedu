{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/billing.invoice_created.v1.json",
  "title": "billing.invoice_created.v1",
  "description": "SaaS subscription invoice created.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "billing.invoice_created.v1"
    },
    "source": {
      "const": "billing-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "invoice_id",
        "tenant_id",
        "subscription_id",
        "amount_cents",
        "status"
      ],
      "properties": {
        "invoice_id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string"
        },
        "subscription_id": {
          "type": "string",
          "format": "uuid"
        },
        "amount_cents": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "billing.invoice_created.v1",
      "source": "billing-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "invoice_id": "11111111-1111-4111-8111-111111111111",
        "tenant_id": "school-a",
        "subscription_id": "11111111-1111-4111-8111-111111111111",
        "amount_cents": 1,
        "status": "example-status"
      }
    }
  ],
  "additionalProperties": false
}
