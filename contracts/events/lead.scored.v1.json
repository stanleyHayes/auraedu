{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/lead.scored.v1.json",
  "title": "lead.scored",
  "description": "PII-free explanation emitted when a rules-based lead score materially changes.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "lead.scored.v1"
    },
    "source": {
      "const": "crm-service"
    },
    "subject": {
      "type": "string",
      "format": "uuid"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": [
        "lead_id",
        "score",
        "confidence",
        "positive_factor_codes",
        "negative_factor_codes",
        "rule_version",
        "evaluated_at"
      ],
      "properties": {
        "lead_id": {
          "type": "string",
          "format": "uuid"
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "positive_factor_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "negative_factor_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rule_version": {
          "type": "string"
        },
        "evaluated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "lead.scored.v1",
      "source": "crm-service",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "lead_id": "11111111-1111-4111-8111-111111111111",
        "score": 1,
        "confidence": "low",
        "positive_factor_codes": [
          "example-positive.factor.codes"
        ],
        "negative_factor_codes": [
          "example-negative.factor.codes"
        ],
        "rule_version": "example-rule.version",
        "evaluated_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
