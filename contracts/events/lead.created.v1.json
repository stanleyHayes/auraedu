{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/lead.created.v1.json",
  "title": "lead.created",
  "description": "Emitted after a tenant-scoped recruitment lead is committed.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "lead.created.v1"
    },
    "source": {
      "const": "crm-service"
    },
    "subject": {
      "type": "string",
      "format": "uuid"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "institution_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "lead_id",
        "stage",
        "source",
        "created_at"
      ],
      "properties": {
        "lead_id": {
          "type": "string",
          "format": "uuid"
        },
        "stage": {
          "const": "new"
        },
        "source": {
          "type": "string"
        },
        "campaign_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "lead.created.v1",
      "source": "crm-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "lead_id": "11111111-1111-4111-8111-111111111111",
        "stage": "new",
        "source": "example-source",
        "created_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
