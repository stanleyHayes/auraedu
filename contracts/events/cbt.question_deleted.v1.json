{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/cbt.question_deleted.v1.json",
  "title": "cbt.question_deleted.v1",
  "description": "CBT question deleted event.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "cbt.question_deleted.v1"
    },
    "source": {
      "const": "cbt-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "question_id",
        "academic_year_id",
        "subject_id",
        "question_type",
        "marks",
        "status"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "format": "uuid"
        },
        "academic_year_id": {
          "type": "string",
          "format": "uuid"
        },
        "subject_id": {
          "type": "string",
          "format": "uuid"
        },
        "question_type": {
          "type": "string"
        },
        "marks": {
          "type": "number"
        },
        "status": {
          "type": "string"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "cbt.question_deleted.v1",
      "source": "cbt-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "question_id": "11111111-1111-4111-8111-111111111111",
        "academic_year_id": "11111111-1111-4111-8111-111111111111",
        "subject_id": "11111111-1111-4111-8111-111111111111",
        "question_type": "example-question.type",
        "marks": 1,
        "status": "example-status"
      }
    }
  ],
  "additionalProperties": false
}
