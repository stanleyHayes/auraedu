{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/intelligence.alert.acknowledged.v1.json",
  "title": "intelligence.alert.acknowledged.v1",
  "description": "PII-free audit event emitted after a human acknowledges a reputation alert.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "intelligence.alert.acknowledged.v1"
    },
    "source": {
      "const": "market-intelligence-service"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "actor_user_id",
        "occurred_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "kind": {
          "const": "reputation"
        },
        "actor_user_id": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "intelligence.alert.acknowledged.v1",
      "source": "market-intelligence-service",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "id": "11111111-1111-4111-8111-111111111111",
        "kind": "reputation",
        "actor_user_id": "example-actor.user.id",
        "occurred_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
