{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/analytics.metric_updated.v1.json",
  "title": "analytics.metric_updated",
  "description": "Emitted when an analytics metric is updated.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "analytics.metric_updated.v1"
    },
    "source": {
      "const": "analytics-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "metric_key",
        "value"
      ],
      "properties": {
        "metric_key": {
          "type": "string"
        },
        "value": {
          "type": "number"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "analytics.metric_updated.v1",
      "source": "analytics-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "metric_key": "example-metric.key",
        "value": 1
      }
    }
  ],
  "additionalProperties": false
}
