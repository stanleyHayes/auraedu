{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.auraedu.dev/events/knowledge.source_approved.v1.json",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "knowledge.source_approved.v1"
    },
    "source": {
      "type": "string"
    },
    "subject": {
      "type": "string",
      "format": "uuid"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "source_id",
        "source_type",
        "locale",
        "version",
        "effective_at"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "format": "uuid"
        },
        "source_type": {
          "type": "string"
        },
        "locale": {
          "enum": [
            "en",
            "en-GH",
            "fr",
            "fr-GH"
          ]
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "effective_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "knowledge.source_approved.v1",
      "source": "example-source",
      "subject": "11111111-1111-4111-8111-111111111111",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-20T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "source_id": "11111111-1111-4111-8111-111111111111",
        "source_type": "example-source.type",
        "locale": "en",
        "version": 1,
        "effective_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
