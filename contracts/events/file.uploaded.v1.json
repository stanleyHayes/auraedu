{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/file.uploaded.v1.json",
  "title": "file.uploaded",
  "description": "Emitted when a file is uploaded to Cloudinary.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "file.uploaded"
    },
    "source": {
      "const": "file-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "file_id",
        "public_id"
      ],
      "properties": {
        "file_id": {
          "type": "string",
          "format": "uuid"
        },
        "public_id": {
          "type": "string"
        },
        "secure_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "folder": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
