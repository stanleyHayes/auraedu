{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/ai.guidance_generated.v1.json",
  "title": "ai.guidance_generated",
  "description": "Emitted when AI career guidance is generated.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "ai.guidance_generated.v1"
    },
    "source": {
      "const": "career-guidance-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "student_id",
        "guidance_type"
      ],
      "properties": {
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "guidance_type": {
          "type": "string"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "explanation": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "ai.guidance_generated.v1",
      "source": "career-guidance-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "student_id": "11111111-1111-4111-8111-111111111111",
        "guidance_type": "example-guidance.type"
      }
    }
  ],
  "additionalProperties": false
}
