{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/payment.failed.v1.json",
  "title": "payment.failed",
  "description": "Emitted when a payment fails.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "payment.failed"
    },
    "source": {
      "const": "payment-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "payment_id"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid"
        },
        "invoice_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
