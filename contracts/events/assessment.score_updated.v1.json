{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/assessment.score_updated.v1.json",
  "title": "assessment.score_updated.v1",
  "description": "Emitted by Assessment Service when an existing score changes. Carries complete current-state context so projections can replace prior values without reading the Assessment database.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "assessment.score_updated.v1"
    },
    "source": {
      "const": "assessment-service"
    },
    "subject": {
      "type": "string",
      "description": "score id"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "score_id",
        "assessment_id",
        "student_id",
        "subject_id",
        "academic_year_id",
        "score",
        "max_score",
        "recorded_at",
        "updated_at",
        "changed_fields"
      ],
      "properties": {
        "score_id": {
          "type": "string",
          "format": "uuid"
        },
        "assessment_id": {
          "type": "string",
          "format": "uuid"
        },
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "subject_id": {
          "type": "string",
          "format": "uuid"
        },
        "academic_year_id": {
          "type": "string",
          "format": "uuid"
        },
        "score": {
          "type": "number",
          "minimum": 0
        },
        "max_score": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "recorded_by": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "changed_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "class_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "assessment.score_updated.v1",
      "source": "assessment-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "score_id": "11111111-1111-4111-8111-111111111111",
        "assessment_id": "11111111-1111-4111-8111-111111111111",
        "student_id": "11111111-1111-4111-8111-111111111111",
        "subject_id": "11111111-1111-4111-8111-111111111111",
        "academic_year_id": "11111111-1111-4111-8111-111111111111",
        "score": 1,
        "max_score": 1,
        "recorded_at": "2026-07-19T10:00:00Z",
        "updated_at": "2026-07-19T10:00:00Z",
        "changed_fields": [
          "example-changed.fields"
        ]
      }
    }
  ]
}
