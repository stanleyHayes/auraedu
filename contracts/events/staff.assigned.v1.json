{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/staff.assigned.v1.json",
  "title": "staff.assigned",
  "description": "Emitted when a staff member is assigned to a class/subject.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "staff.assigned"
    },
    "source": {
      "const": "staff-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "staff_id"
      ],
      "properties": {
        "staff_id": {
          "type": "string",
          "format": "uuid"
        },
        "class_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "subject_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "role": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
