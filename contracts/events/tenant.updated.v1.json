{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.auraedu.dev/events/tenant.updated.v1.json",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "tenant.updated.v1"
    },
    "source": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "tenant_code",
        "name",
        "status",
        "plan"
      ],
      "properties": {
        "tenant_code": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "active",
            "onboarding",
            "suspended"
          ]
        },
        "plan": {
          "enum": [
            "core",
            "starter",
            "growth",
            "professional",
            "ai_plus",
            "enterprise"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "tenant.updated.v1",
      "source": "example-source",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-20T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "tenant_code": "example-tenant.code",
        "name": "example-name",
        "status": "active",
        "plan": "core"
      }
    }
  ]
}
