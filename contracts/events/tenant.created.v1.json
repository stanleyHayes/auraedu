{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "tenant_id", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "type": { "const": "tenant.created.v1" },
    "source": { "type": "string" },
    "id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string" },
    "datacontenttype": { "const": "application/json" },
    "data": {
      "type": "object",
      "required": ["tenant_code", "name"],
      "properties": {
        "tenant_code": { "type": "string" },
        "name": { "type": "string" },
        "plan": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
