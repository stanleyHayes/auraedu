{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/invoice.updated.v1.json",
  "title": "invoice.updated.v1",
  "description": "Learner fee invoice.updated.v1.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "invoice.updated.v1"
    },
    "source": {
      "const": "fees-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "invoice_id",
        "student_id",
        "fee_structure_id",
        "amount_cents",
        "balance_cents",
        "status",
        "due_date",
        "issued_at"
      ],
      "properties": {
        "invoice_id": {
          "type": "string",
          "format": "uuid"
        },
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "fee_structure_id": {
          "type": "string",
          "format": "uuid"
        },
        "amount_due": {
          "type": "number"
        },
        "balance_due": {
          "type": "number"
        },
        "amount_cents": {
          "type": "integer"
        },
        "balance_cents": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "invoice.updated.v1",
      "source": "fees-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "invoice_id": "11111111-1111-4111-8111-111111111111",
        "student_id": "11111111-1111-4111-8111-111111111111",
        "fee_structure_id": "11111111-1111-4111-8111-111111111111",
        "amount_cents": 1,
        "balance_cents": 1,
        "status": "example-status",
        "due_date": "2026-07-19",
        "issued_at": "2026-07-19T10:00:00Z"
      }
    }
  ],
  "additionalProperties": false
}
