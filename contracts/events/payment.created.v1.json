{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/payment.created.v1.json",
  "title": "payment.created.v1",
  "description": "Payment created event.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "payment.created.v1"
    },
    "source": {
      "const": "payment-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "payment_id",
        "invoice_id",
        "amount",
        "amount_cents",
        "currency",
        "provider",
        "status",
        "initiated_at"
      ],
      "properties": {
        "payment_id": {
          "type": "string",
          "format": "uuid"
        },
        "invoice_id": {
          "type": "string",
          "format": "uuid"
        },
        "amount": {
          "type": "integer"
        },
        "amount_cents": {
          "type": "integer"
        },
        "currency": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "gateway": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "initiated_at": {
          "type": "string",
          "format": "date-time"
        },
        "provider_reference": {
          "type": "string"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "payment.created.v1",
      "source": "payment-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "payment_id": "11111111-1111-4111-8111-111111111111",
        "invoice_id": "11111111-1111-4111-8111-111111111111",
        "amount": 1,
        "amount_cents": 1,
        "currency": "example-currency",
        "provider": "example-provider",
        "status": "example-status",
        "initiated_at": "2026-07-19T10:00:00Z"
      }
    }
  ],
  "additionalProperties": false
}
