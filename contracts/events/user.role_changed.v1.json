{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/user.role_changed.v1.json",
  "title": "user.role_changed",
  "description": "Emitted when a user's role or permissions change.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "user.role_changed"
    },
    "source": {
      "const": "identity-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "user_id",
        "role"
      ],
      "properties": {
        "user_id": {
          "type": "string",
          "format": "uuid"
        },
        "role": {
          "type": "string"
        },
        "previous_role": {
          "type": [
            "string",
            "null"
          ]
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
