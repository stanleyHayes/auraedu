{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/student.updated.v1.json",
  "title": "student.updated",
  "description": "Emitted when a student record is updated.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "student.updated"
    },
    "source": {
      "const": "student-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "student_id"
      ],
      "properties": {
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
