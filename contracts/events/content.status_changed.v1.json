{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.auraedu.dev/events/content.status_changed.v1.json",
  "title": "content.status_changed.v1",
  "description": "A content version moved through review. Content and review text are deliberately excluded.",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "tenant_id", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "type": { "const": "content.status_changed.v1" },
    "source": { "type": "string" },
    "id": { "type": "string", "format": "uuid" },
    "time": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "datacontenttype": { "const": "application/json" },
    "data": {
      "type": "object",
      "required": ["content_id", "version", "previous_status", "status", "actor_id", "changed_at"],
      "properties": {
        "content_id": { "type": "string", "format": "uuid" },
        "version": { "type": "integer", "minimum": 1 },
        "previous_status": { "type": "string" },
        "status": { "type": "string" },
        "actor_id": { "type": "string" },
        "changed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [{
    "specversion": "1.0",
    "type": "content.status_changed.v1",
    "source": "content-service",
    "id": "11111111-1111-4111-8111-111111111111",
    "time": "2026-07-21T10:00:00Z",
    "tenant_id": "school-a",
    "data": {
      "content_id": "22222222-2222-4222-8222-222222222222",
      "version": 1,
      "previous_status": "draft",
      "status": "pending_review",
      "actor_id": "33333333-3333-4333-8333-333333333333",
      "changed_at": "2026-07-21T10:00:00Z"
    }
  }]
}
