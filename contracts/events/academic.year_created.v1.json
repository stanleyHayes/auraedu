{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/academic.year_created.v1.json",
  "title": "academic.year_created",
  "description": "Emitted when an academic year is created.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "academic.year_created"
    },
    "source": {
      "const": "academic-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "year_id",
        "name"
      ],
      "properties": {
        "year_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
