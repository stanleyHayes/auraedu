{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/communication.journey_changed.v1.json",
  "title": "communication.journey_changed",
  "description": "Privacy-safe audit fact emitted when a communication journey is created or changes lifecycle state.",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "tenant_id", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "type": { "const": "communication.journey_changed.v1" },
    "source": { "const": "notification-service" },
    "subject": { "type": "string" },
    "id": { "type": "string", "format": "uuid" },
    "time": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "datacontenttype": { "const": "application/json" },
    "data": {
      "type": "object",
      "required": ["journey_id", "status", "trigger_event", "version", "step_count", "changed_by", "changed_at"],
      "properties": {
        "journey_id": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["draft", "active", "paused", "archived"] },
        "trigger_event": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "step_count": { "type": "integer", "minimum": 1, "maximum": 10 },
        "changed_by": { "type": "string", "format": "uuid" },
        "changed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "communication.journey_changed.v1",
      "source": "notification-service",
      "subject": "11111111-1111-4111-8111-111111111111",
      "id": "22222222-2222-4222-8222-222222222222",
      "time": "2026-07-21T12:00:00Z",
      "tenant_id": "school-a",
      "datacontenttype": "application/json",
      "data": {
        "journey_id": "11111111-1111-4111-8111-111111111111",
        "status": "active",
        "trigger_event": "application.started.v1",
        "version": 1,
        "step_count": 2,
        "changed_by": "33333333-3333-4333-8333-333333333333",
        "changed_at": "2026-07-21T12:00:00Z"
      }
    }
  ]
}
