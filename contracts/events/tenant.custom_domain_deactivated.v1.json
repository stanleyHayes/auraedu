{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.auraedu.dev/events/tenant.custom_domain_deactivated.v1.json",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "tenant_id", "data"],
  "properties": {
    "specversion": { "const": "1.0" },
    "type": { "const": "tenant.custom_domain_deactivated.v1" },
    "source": { "type": "string" },
    "id": { "type": "string", "format": "uuid" },
    "time": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "datacontenttype": { "const": "application/json" },
    "data": {
      "type": "object",
      "required": ["tenant_code", "hostname"],
      "properties": {
        "tenant_code": { "type": "string", "minLength": 1 },
        "hostname": { "type": "string", "minLength": 4, "maxLength": 253 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [{
    "specversion": "1.0",
    "type": "tenant.custom_domain_deactivated.v1",
    "source": "tenant-service",
    "id": "11111111-1111-4111-8111-111111111111",
    "time": "2026-07-20T10:00:00Z",
    "tenant_id": "school-a",
    "data": { "tenant_code": "school-a", "hostname": "school.edu.gh" }
  }]
}
