{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/cbt.graded.v1.json",
  "title": "cbt.graded",
  "description": "Emitted when a CBT submission is graded.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "cbt.graded.v1"
    },
    "source": {
      "const": "cbt-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "submission_id",
        "score"
      ],
      "properties": {
        "submission_id": {
          "type": "string",
          "format": "uuid"
        },
        "score": {
          "type": "number",
          "minimum": 0
        },
        "max_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "cbt.graded.v1",
      "source": "cbt-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "submission_id": "11111111-1111-4111-8111-111111111111",
        "score": 1
      }
    }
  ],
  "additionalProperties": false
}
