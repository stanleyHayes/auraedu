{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/report.created.v1.json",
  "title": "report.created.v1",
  "description": "Report template or card created event.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "report.created.v1"
    },
    "source": {
      "const": "report-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [],
      "properties": {
        "report_template_id": {
          "type": "string",
          "format": "uuid"
        },
        "report_card_id": {
          "type": "string",
          "format": "uuid"
        },
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "academic_year_id": {
          "type": "string",
          "format": "uuid"
        },
        "term_id": {
          "type": "string",
          "format": "uuid"
        },
        "template_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "file_url": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "changed_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "report_template_id"
          ]
        },
        {
          "required": [
            "report_card_id"
          ]
        }
      ],
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "report.created.v1",
      "source": "report-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "report_template_id": "11111111-1111-4111-8111-111111111111"
      }
    }
  ],
  "additionalProperties": false
}
