{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/report.published.v1.json",
  "title": "report.published",
  "description": "Emitted when a report card is published.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "report.published"
    },
    "source": {
      "const": "report-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "report_card_id",
        "student_id",
        "term_id"
      ],
      "properties": {
        "report_card_id": {
          "type": "string",
          "format": "uuid"
        },
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "term_id": {
          "type": "string",
          "format": "uuid"
        },
        "file_url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
