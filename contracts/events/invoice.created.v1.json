{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/invoice.created.v1.json",
  "title": "invoice.created",
  "description": "Emitted when an invoice is created.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "invoice.created"
    },
    "source": {
      "const": "fees-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "invoice_id",
        "student_id",
        "amount_due"
      ],
      "properties": {
        "invoice_id": {
          "type": "string",
          "format": "uuid"
        },
        "student_id": {
          "type": "string",
          "format": "uuid"
        },
        "amount_due": {
          "type": "number",
          "minimum": 0
        },
        "due_date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    }
  }
}
