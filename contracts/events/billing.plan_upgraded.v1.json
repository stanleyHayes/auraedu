{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/billing.plan_upgraded.v1.json",
  "title": "billing.plan_upgraded",
  "description": "Emitted when a tenant upgrades their plan.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "billing.plan_upgraded.v1"
    },
    "source": {
      "const": "billing-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "plan_id",
        "plan_code",
        "name",
        "price_cents",
        "currency",
        "tenant_id",
        "previous_plan"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "format": "uuid"
        },
        "plan_code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "price_cents": {
          "type": "integer"
        },
        "currency": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string"
        },
        "previous_plan": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "billing.plan_upgraded.v1",
      "source": "billing-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "plan_id": "11111111-1111-4111-8111-111111111111",
        "plan_code": "example-plan.code",
        "name": "example-name",
        "price_cents": 1,
        "currency": "example-currency",
        "tenant_id": "school-a",
        "previous_plan": "example-previous.plan"
      }
    }
  ],
  "additionalProperties": false
}
