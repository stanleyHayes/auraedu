{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/billing.plan_upgraded.v1.json",
  "title": "billing.plan_upgraded",
  "description": "Emitted when a tenant upgrades their plan.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "billing.plan_upgraded"
    },
    "source": {
      "const": "billing-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "tenant_id",
        "plan"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "plan": {
          "type": "string"
        },
        "previous_plan": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
