{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/fee.assigned.v1.json",
  "title": "fee.assigned",
  "description": "Emitted when a fee structure is assigned to a class.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "fee.assigned"
    },
    "source": {
      "const": "fees-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "fee_structure_id"
      ],
      "properties": {
        "fee_structure_id": {
          "type": "string",
          "format": "uuid"
        },
        "class_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "amount": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    }
  }
}
