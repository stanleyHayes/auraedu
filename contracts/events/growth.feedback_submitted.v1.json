{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/growth.feedback_submitted.v1.json",
  "title": "growth.feedback_submitted",
  "description": "Emitted when prospect or staff feedback is accepted for controlled review.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "growth.feedback_submitted.v1"
    },
    "source": {
      "enum": [
        "crm-service",
        "ai-orchestrator-service"
      ]
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "feedback_id",
        "feedback_type",
        "submitted_at"
      ],
      "properties": {
        "feedback_id": {
          "type": "string",
          "format": "uuid"
        },
        "interaction_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "ai_run_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "feedback_type": {
          "type": "string"
        },
        "rating": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 5
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "growth.feedback_submitted.v1",
      "source": "crm-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "feedback_id": "11111111-1111-4111-8111-111111111111",
        "feedback_type": "example-feedback.type",
        "submitted_at": "2026-07-19T10:00:00Z"
      }
    }
  ]
}
