{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/notification.failed.v1.json",
  "title": "notification.failed",
  "description": "Emitted when a notification fails to send.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "notification.failed.v1"
    },
    "source": {
      "const": "notification-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "message_id",
        "channel"
      ],
      "properties": {
        "message_id": {
          "type": "string",
          "format": "uuid"
        },
        "channel": {
          "type": "string",
          "enum": [
            "email",
            "sms",
            "whatsapp",
            "in_app",
            "push"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "notification.failed.v1",
      "source": "notification-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "message_id": "11111111-1111-4111-8111-111111111111",
        "channel": "email"
      }
    }
  ],
  "additionalProperties": false
}
