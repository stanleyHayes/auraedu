{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/notification.failed.v1.json",
  "title": "notification.failed",
  "description": "Emitted when a notification fails to send.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "notification.failed"
    },
    "source": {
      "const": "notification-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "message_id",
        "channel"
      ],
      "properties": {
        "message_id": {
          "type": "string",
          "format": "uuid"
        },
        "channel": {
          "type": "string",
          "enum": [
            "email",
            "sms",
            "whatsapp",
            "in_app"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
