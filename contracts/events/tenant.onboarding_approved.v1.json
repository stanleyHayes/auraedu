{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.auraedu.dev/events/tenant.onboarding_approved.v1.json",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "tenant.onboarding_approved.v1"
    },
    "source": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "request_id",
        "tenant_code",
        "plan"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_code": {
          "type": "string"
        },
        "plan": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "specversion": "1.0",
      "type": "tenant.onboarding_approved.v1",
      "source": "example-source",
      "id": "11111111-1111-4111-8111-111111111111",
      "time": "2026-07-20T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "request_id": "11111111-1111-4111-8111-111111111111",
        "tenant_code": "example-tenant.code",
        "plan": "example-plan"
      }
    }
  ]
}
