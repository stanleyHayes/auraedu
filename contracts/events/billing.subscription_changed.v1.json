{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/billing.subscription_changed.v1.json",
  "title": "billing.subscription_changed",
  "description": "Emitted when a tenant subscription changes.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "billing.subscription_changed.v1"
    },
    "source": {
      "const": "billing-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "subscription_id",
        "tenant_id",
        "plan_id",
        "plan_key",
        "status"
      ],
      "properties": {
        "subscription_id": {
          "type": "string",
          "format": "uuid"
        },
        "tenant_id": {
          "type": "string"
        },
        "plan_id": {
          "type": "string",
          "format": "uuid"
        },
        "plan_key": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "billing.subscription_changed.v1",
      "source": "billing-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "subscription_id": "11111111-1111-4111-8111-111111111111",
        "tenant_id": "school-a",
        "plan_id": "11111111-1111-4111-8111-111111111111",
        "plan_key": "example-plan.key",
        "status": "example-status"
      }
    }
  ],
  "additionalProperties": false
}
