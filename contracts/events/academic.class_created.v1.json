{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.auraedu.dev/events/academic.class_created.v1.json",
  "title": "academic.class_created",
  "description": "Emitted when a class is created.",
  "type": "object",
  "required": [
    "specversion",
    "type",
    "source",
    "id",
    "time",
    "tenant_id",
    "data"
  ],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "type": {
      "const": "academic.class_created.v1"
    },
    "source": {
      "const": "academic-service"
    },
    "subject": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "class_id",
        "name",
        "academic_year_id"
      ],
      "properties": {
        "class_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "academic_year_id": {
          "type": "string",
          "format": "uuid"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "specversion": "1.0",
      "type": "academic.class_created.v1",
      "source": "academic-service",
      "id": "example-id",
      "time": "2026-07-19T10:00:00Z",
      "tenant_id": "school-a",
      "data": {
        "class_id": "11111111-1111-4111-8111-111111111111",
        "name": "example-name",
        "academic_year_id": "11111111-1111-4111-8111-111111111111"
      }
    }
  ],
  "additionalProperties": false
}
