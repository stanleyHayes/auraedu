{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "build": "expo export --platform android --output-dir dist/android --clear",
    "release:check": "node scripts/verify-release.mjs",
    "ota:check": "node scripts/verify-release.mjs",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.ts"
  },
  "dependencies": {
    "@auraedu/api-client": "workspace:*",
    "@auraedu/tokens": "workspace:*",
    "@auraedu/ui-native": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-speech": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-updates": "~57.0.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3"
  }
}
