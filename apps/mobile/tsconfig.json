{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "react"],
    "paths": {
      "@auraedu/api-client": ["../../packages/api-client/src/index.ts"],
      "@auraedu/tokens": ["../../packages/tokens/src/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
