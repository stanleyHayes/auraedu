{
  "name": "@auraedu/shared-types",
  "version": "0.1.0",
  "description": "Types generated from AuraEDU OpenAPI + CloudEvents contracts (L0).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openapi/*": {
      "import": "./dist/generated/openapi/*.js",
      "types": "./dist/generated/openapi/*.d.ts"
    },
    "./events": {
      "import": "./dist/generated/events/index.js",
      "types": "./dist/generated/events/index.d.ts"
    }
  },
  "files": [
    "dist",
    "gen"
  ],
  "scripts": {
    "generate": "pnpm --filter @auraedu/codegen run generate",
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@auraedu/codegen": "workspace:*",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
