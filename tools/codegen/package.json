{
  "name": "@auraedu/codegen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AuraEDU contract codegen: OpenAPI → Go/TS, CloudEvents JSON Schema → validators/types.",
  "scripts": {
    "generate": "tsc -p tsconfig.json && node dist/generate.js",
    "validate:events": "tsc -p tsconfig.json && node dist/validate-events.js",
    "validate:routes": "tsc -p tsconfig.json && node dist/validate-routes.js",
    "normalize:openapi": "tsc -p tsconfig.json && node dist/normalize-openapi-metadata.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "tsc -p tsconfig.json && node --test dist/*.test.js",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "js-yaml": "^4.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
