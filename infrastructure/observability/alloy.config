discovery.docker "auraedu" {
	host = "unix:///var/run/docker.sock"
}

discovery.relabel "auraedu_logs" {
	targets = discovery.docker.auraedu.targets

	// Docker discovery is host-wide. Keep this collector inside the AuraEDU
	// boundary so unrelated local projects are never forwarded to AuraEDU Loki.
	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
		regex         = "auraedu(-infra)?"
		action        = "keep"
	}

	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "service_name"
	}

	// Prefer the stable Compose service name over generated container names so
	// Grafana's service selector joins logs, metrics, and traces consistently.
	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_service"]
		regex         = "(.+)"
		target_label  = "service_name"
	}

	rule {
		source_labels = ["__meta_docker_container_label_com_docker_compose_project"]
		target_label  = "compose_project"
	}
}

loki.source.docker "auraedu" {
	host       = "unix:///var/run/docker.sock"
	targets    = discovery.relabel.auraedu_logs.output
	labels     = {platform = "auraedu", environment = "local"}
	forward_to = [loki.write.local.receiver]
}

loki.write "local" {
	endpoint {
		url = "http://loki:3100/loki/api/v1/push"
	}
}
