{
  "annotations": { "list": [] },
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Requests / second",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(auraedu_http_requests_total{service=~\"$service\"}[5m]))", "legendFormat": "RPS", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "5xx error ratio",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(auraedu_http_requests_total{service=~\"$service\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(auraedu_http_requests_total{service=~\"$service\"}[5m])), 0.001)", "legendFormat": "error ratio", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(auraedu_http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "p95", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Unavailable targets",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "count(up{job=\"auraedu-services\"} == 0)", "legendFormat": "down", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Request rate by service",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "targets": [{ "expr": "sum by (service) (rate(auraedu_http_requests_total{service=~\"$service\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by service",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (service, le) (rate(auraedu_http_request_duration_seconds_bucket{service=~\"$service\"}[5m])))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "type": "logs",
      "title": "Structured service logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "expr": "{platform=\"auraedu\", service_name=~\"$service\"}", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["auraedu", "golden-signals"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(auraedu_http_requests_total, service)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "AuraEDU Golden Signals",
  "uid": "auraedu-golden-signals",
  "version": 1
}
